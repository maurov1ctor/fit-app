// schema.prisma (atualizado para incluir RefreshToken)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum para roles de usuário
enum UserRole {
  PROFESSOR
  ALUNO
  ADMIN
}

// ... (outros enums e modelos do schema anterior)

// Modelo para refresh tokens
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relacionamento
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Índices
  @@index([userId])
  @@index([expiresAt])
}

// Adicionar ao modelo User
model User {
  // ... campos existentes
  refreshTokens RefreshToken[]

  // ... relacionamentos existentes
}